{
  "name": "mimocode-gui",
  "version": "1.0.0",
  "description": "MiMoCode Desktop GUI",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "tsc -p tsconfig.electron.json && vite build && npx electron .",
    "electron:build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "package": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
