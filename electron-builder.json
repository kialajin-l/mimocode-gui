{
  "appId": "com.mimocode.desktop",
  "productName": "MiMoCode",
  "directories": {
    "output": "release"
  },
  "files": [
    "build/icons/**/*",
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "target": ["nsis"],
    "icon": "build/icons/icon.ico"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "build/icons/icon.png"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "build/icons/icon.png"
  }
}
